{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/slides/**",
              "components/studio/**",
              "ui_kits/studio/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Anton|Archivo|Saira Condensed))/i]",
        "message": "Font not provided by the design system. Available: Anton, Archivo, Saira Condensed."
      },
      {
        "selector": "JSXOpeningElement[name.name='BrandHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:dark|ring|handle|key|ref|className|style|children)$/]",
        "message": "<BrandHeader> doesn't accept that prop. Declared props: dark, ring, handle."
      },
      {
        "selector": "JSXOpeningElement[name.name='BreathSlide'] > JSXAttribute > JSXIdentifier[name!=/^(?:quote|quoteAccent|sig|key|ref|className|style|children)$/]",
        "message": "<BreathSlide> doesn't accept that prop. Declared props: quote, quoteAccent, sig."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|active|onClick|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: children, active, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='CoverSlide'] > JSXAttribute > JSXIdentifier[name!=/^(?:serie|variant|title|greenWord|body|cur|tot|mediaUrl|showSwipe|showPagination|key|ref|className|style|children)$/]",
        "message": "<CoverSlide> doesn't accept that prop. Declared props: serie, variant, title, greenWord, body, cur, tot, mediaUrl, showSwipe, showPagination."
      },
      {
        "selector": "JSXOpeningElement[name.name='CoverSlide'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:cover|titre|corps)$/]",
        "message": "<CoverSlide> variant must be one of 'cover' | 'titre' | 'corps'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CTASlide'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|greenWord|body|btnlabel|sig|onSig|key|ref|className|style|children)$/]",
        "message": "<CTASlide> doesn't accept that prop. Declared props: title, greenWord, body, btnlabel, sig, onSig."
      },
      {
        "selector": "JSXOpeningElement[name.name='QuoteSlide'] > JSXAttribute > JSXIdentifier[name!=/^(?:quote|quoteAccent|quoteAuthor|caption|cur|tot|accent|key|ref|className|style|children)$/]",
        "message": "<QuoteSlide> doesn't accept that prop. Declared props: quote, quoteAccent, quoteAuthor, caption, cur, tot, accent."
      },
      {
        "selector": "JSXOpeningElement[name.name='RangeRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|min|max|step|onChange|display|key|ref|className|style|children)$/]",
        "message": "<RangeRow> doesn't accept that prop. Declared props: label, value, min, max, step, onChange, display."
      },
      {
        "selector": "JSXOpeningElement[name.name='SerieButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|description|swatch|active|onClick|key|ref|className|style|children)$/]",
        "message": "<SerieButton> doesn't accept that prop. Declared props: name, description, swatch, active, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='SeriesTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|bg|color|key|ref|className|style|children)$/]",
        "message": "<SeriesTag> doesn't accept that prop. Declared props: label, bg, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='StudioButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|onClick|key|ref|className|style|children)$/]",
        "message": "<StudioButton> doesn't accept that prop. Declared props: children, variant, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='StudioButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|ghost)$/]",
        "message": "<StudioButton> variant must be one of 'primary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ToggleSwitch'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|on|onChange|key|ref|className|style|children)$/]",
        "message": "<ToggleSwitch> doesn't accept that prop. Declared props: label, on, onChange."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
